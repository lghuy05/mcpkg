{
  "name": "mcpkg",
  "version": "0.1.0-alpha.0",
  "description": "Community package manager for MCP servers",
  "main": "dist/index.js",
  "bin": {
    "mcpkg": "./dist/index.js"
  },
  "scripts": {
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "smoke": "npm run build && node scripts/smoke-pack.mjs",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "watch": "tsc --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lghuy05/mcpkg.git"
  },
  "keywords": [
    "mcp",
    "ai",
    "cli",
    "agent",
    "tools"
  ],
  "author": "Huy Luong",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/lghuy05/mcpkg/issues"
  },
  "homepage": "https://github.com/lghuy05/mcpkg#readme",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.4.1",
    "ora": "^9.3.0"
  }
}
